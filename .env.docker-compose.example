DATABASE_URL="postgresql://postgres:postgres@postgres:5432/noveshop?schema=public"
NOVESHOP_POSTGRES_DB="noveshop"
NOVESHOP_POSTGRES_USER="postgres"
NOVESHOP_POSTGRES_PASSWORD="postgres"

SHOP_PUBLIC_BASE_URL="https://shop.example.com"

ADMIN_USERNAME="admin"
# Generate with:
# docker compose -f deploy/docker-compose.prod.yml run --rm web npm run security:hash-admin -- 'replace-with-a-strong-password'
ADMIN_PASSWORD_HASH="replace-with-generated-password-hash"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
MERCHANT_SESSION_SECRET="replace-with-a-second-long-random-secret"
DATA_ENCRYPTION_KEY="replace-with-a-32-byte-or-longer-random-secret"

NOVAPAY_BASE_URL="https://pay.example.com"
DEFAULT_CHANNEL_CODE="alipay.page"

# Keep disabled in multi-merchant production.
ALLOW_ENV_PAYMENT_PROFILE_BOOTSTRAP="false"
NOVAPAY_MERCHANT_CODE=""
NOVAPAY_API_KEY=""
NOVAPAY_API_SECRET=""
NOVAPAY_NOTIFY_SECRET=""
